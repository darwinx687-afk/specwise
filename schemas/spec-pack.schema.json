{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specwise.dev/schemas/spec-pack.schema.json",
  "title": "SpecWise Spec Pack",
  "description": "Machine-readable SpecWise Spec Pack Standard v0.1 structure.",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "sourceMaterials",
    "modules",
    "pages",
    "entities",
    "fields",
    "roles",
    "permissions",
    "workflows",
    "acceptanceCriteria",
    "openQuestions",
    "assumptions",
    "buildability",
    "generatedAt",
    "generator"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "sourceMaterials": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceMaterial"
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/module"
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/page"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/field"
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/role"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/permission"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflow"
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/acceptanceCriterion"
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/openQuestion"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assumption"
      }
    },
    "buildability": {
      "$ref": "#/$defs/buildability"
    },
    "handoff": {
      "$ref": "#/$defs/handoff"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "$ref": "#/$defs/generator"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "confidence": {
      "enum": ["high", "medium", "low", "unknown"]
    },
    "status": {
      "enum": ["review_required", "ready_for_ai_coding", "needs_discovery", "not_buildable_yet"]
    },
    "reviewable": {
      "type": "object",
      "required": ["confidence", "evidenceIds", "needsReview"],
      "properties": {
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "needsReview": {
          "type": "boolean"
        },
        "openQuestionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "project": {
      "type": "object",
      "required": ["name", "domain", "description", "primaryLanguage", "targetUsers", "status"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "primaryLanguage": {
          "type": "string"
        },
        "targetUsers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "$ref": "#/$defs/status"
        }
      },
      "additionalProperties": true
    },
    "sourceMaterial": {
      "type": "object",
      "required": ["id", "type", "path", "language", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": ["screenshot", "markdown", "txt", "csv", "xlsx"]
        },
        "path": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "detectedSignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "module": {
      "allOf": [
        {
          "$ref": "#/$defs/reviewable"
        },
        {
          "type": "object",
          "required": ["id", "name", "nameZh", "description", "pages"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "nameZh": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "pages": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "page": {
      "allOf": [
        {
          "$ref": "#/$defs/reviewable"
        },
        {
          "type": "object",
          "required": ["id", "moduleId", "name", "nameZh", "purpose", "mainActions", "visibleFields"],
          "properties": {
            "id": {
              "type": "string"
            },
            "moduleId": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "nameZh": {
              "type": "string"
            },
            "purpose": {
              "type": "string"
            },
            "mainActions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "visibleFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "entity": {
      "allOf": [
        {
          "$ref": "#/$defs/reviewable"
        },
        {
          "type": "object",
          "required": ["id", "name", "nameZh", "description", "fields", "relations"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "nameZh": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "relations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/relation"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "relation": {
      "type": "object",
      "required": ["type", "targetEntityId", "confidence", "needsReview"],
      "properties": {
        "type": {
          "type": "string"
        },
        "targetEntityId": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "needsReview": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "field": {
      "type": "object",
      "required": ["id", "entityId", "name", "nameZh", "type", "required", "confidence", "needsReview"],
      "properties": {
        "id": {
          "type": "string"
        },
        "entityId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "nameZh": {
          "type": "string"
        },
        "type": {
          "enum": ["string", "number", "boolean", "date", "datetime", "enum", "relation", "currency", "percentage", "text", "json", "unknown"]
        },
        "required": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "const": "unknown"
            }
          ]
        },
        "examples": {
          "type": "array",
          "items": {}
        },
        "possibleValues": {
          "type": "array",
          "items": {}
        },
        "source": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "needsReview": {
          "type": "boolean"
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "openQuestionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "role": {
      "allOf": [
        {
          "$ref": "#/$defs/reviewable"
        },
        {
          "type": "object",
          "required": ["id", "name", "nameZh", "description", "scope"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "nameZh": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "scope": {
              "enum": ["global", "company", "department", "group", "self", "custom", "unknown"]
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "permission": {
      "allOf": [
        {
          "$ref": "#/$defs/reviewable"
        },
        {
          "type": "object",
          "required": ["id", "roleId", "resourceType", "action", "dataScope", "condition"],
          "properties": {
            "id": {
              "type": "string"
            },
            "roleId": {
              "type": "string"
            },
            "resourceType": {
              "type": "string"
            },
            "action": {
              "enum": ["view", "create", "edit", "delete", "approve", "export", "import", "assign", "configure", "unknown"]
            },
            "dataScope": {
              "enum": ["all", "company", "department", "group", "self", "assigned", "none", "unknown"]
            },
            "condition": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "workflow": {
      "allOf": [
        {
          "$ref": "#/$defs/reviewable"
        },
        {
          "type": "object",
          "required": ["id", "name", "nameZh", "trigger", "actors", "steps", "states"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "nameZh": {
              "type": "string"
            },
            "trigger": {
              "type": "string"
            },
            "actors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "steps": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/workflowStep"
              }
            },
            "states": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "workflowStep": {
      "type": "object",
      "required": ["id", "name", "actor", "action", "fromState", "toState", "confidence"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "actor": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "fromState": {
          "type": "string"
        },
        "toState": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      },
      "additionalProperties": true
    },
    "acceptanceCriterion": {
      "type": "object",
      "required": ["id", "title", "description", "category", "priority", "confidence", "needsReview"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "enum": ["module", "entity", "permission", "workflow", "data_import", "ui", "audit", "security", "edge_case"]
        },
        "priority": {
          "enum": ["high", "medium", "low"]
        },
        "relatedModuleIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedQuestionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "needsReview": {
          "type": "boolean"
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "openQuestion": {
      "type": "object",
      "required": ["id", "question", "questionZh", "category", "priority", "blockedItems", "suggestedOwner", "whyItMatters"],
      "properties": {
        "id": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "questionZh": {
          "type": "string"
        },
        "category": {
          "enum": ["module", "entity", "field", "permission", "workflow", "data", "ui", "integration", "audit", "security", "business_rule"]
        },
        "priority": {
          "enum": ["high", "medium", "low"]
        },
        "blockedItems": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggestedOwner": {
          "enum": ["business_owner", "product_manager", "developer", "admin", "legal_or_compliance", "unknown"]
        },
        "whyItMatters": {
          "type": "string"
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "assumption": {
      "type": "object",
      "required": ["id", "statement", "statementZh", "reason", "confidence", "needsReview", "relatedQuestionIds"],
      "properties": {
        "id": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        },
        "statementZh": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "needsReview": {
          "type": "boolean"
        },
        "relatedQuestionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "buildability": {
      "type": "object",
      "required": ["score", "status", "dimensionScores", "mainBlockers", "recommendedNextActions"],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "dimensionScores": {
          "type": "object",
          "required": [
            "moduleClarity",
            "entityClarity",
            "fieldClarity",
            "permissionClarity",
            "workflowClarity",
            "evidenceCoverage",
            "ambiguityControl"
          ],
          "properties": {
            "moduleClarity": {
              "$ref": "#/$defs/weightedScore15"
            },
            "entityClarity": {
              "$ref": "#/$defs/weightedScore15"
            },
            "fieldClarity": {
              "$ref": "#/$defs/weightedScore15"
            },
            "permissionClarity": {
              "$ref": "#/$defs/weightedScore15"
            },
            "workflowClarity": {
              "$ref": "#/$defs/weightedScore15"
            },
            "evidenceCoverage": {
              "$ref": "#/$defs/weightedScore15"
            },
            "ambiguityControl": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            }
          },
          "additionalProperties": false
        },
        "mainBlockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendedNextActions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "weightedScore15": {
      "type": "integer",
      "minimum": 0,
      "maximum": 15
    },
    "handoff": {
      "type": "object",
      "properties": {
        "recommendedNextStep": {
          "type": "string"
        },
        "codingAgentReadiness": {
          "$ref": "#/$defs/status"
        },
        "suggestedImplementationOrder": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockedByQuestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "generator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}

