{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specwise.local/schemas/ai-patch.schema.json",
  "title": "SpecWise AI Patch Contract v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "patchId", "source", "target", "candidates", "safety", "generatedAt"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "patchId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "provider", "mode", "networkCalls"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["mock_ai_patch", "future_provider_patch"]
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["offline_fixture", "dry_run", "disabled"]
        },
        "networkCalls": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draftSpecPackPath", "projectName"],
      "properties": {
        "draftSpecPackPath": {
          "type": "string",
          "minLength": 1
        },
        "projectName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewRequired", "noSilentOverwrite", "evidenceFirst"],
      "properties": {
        "reviewRequired": {
          "type": "boolean",
          "const": true
        },
        "noSilentOverwrite": {
          "type": "boolean",
          "const": true
        },
        "evidenceFirst": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "targetSection", "targetId", "operation", "title", "proposal", "confidence", "needsReview", "rationale"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["confirmed_candidate", "assumption_candidate", "question_candidate", "conflict_candidate"]
        },
        "targetSection": {
          "type": "string",
          "enum": [
            "modules",
            "entities",
            "fields",
            "roles",
            "permissions",
            "workflows",
            "acceptanceCriteria",
            "openQuestions",
            "assumptions",
            "buildability",
            "bilingualSummary"
          ]
        },
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "enum": ["add", "update", "add_question", "add_assumption", "flag_conflict", "rescore"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "titleZh": {
          "type": "string"
        },
        "proposal": {
          "type": "object"
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "needsReview": {
          "type": "boolean",
          "const": true
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
