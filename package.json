{
  "name": "specwise",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Local-first SpecWise v0.1 toolkit for reviewable, evidence-based spec packs.",
  "type": "module",
  "bin": {
    "specwise": "./bin/specwise.mjs"
  },
  "scripts": {
    "validate": "npm run validate:examples",
    "validate:minimal": "node bin/specwise.mjs validate examples/minimal/spec-pack",
    "validate:legacy": "node bin/specwise.mjs validate examples/legacy-staff-evaluation/expected-output/spec-pack",
    "validate:crm": "node bin/specwise.mjs validate examples/legacy-crm-follow-up/expected-output/spec-pack",
    "validate:examples": "node bin/specwise.mjs validate examples/minimal/spec-pack examples/legacy-staff-evaluation/expected-output/spec-pack examples/legacy-crm-follow-up/expected-output/spec-pack",
    "validate:invalid": "node bin/specwise.mjs validate examples/invalid/missing-buildability/spec-pack --expect-fail",
    "validate:pack": "node scripts/validate-spec-pack.mjs",
    "cli:help": "node bin/specwise.mjs --help",
    "cli:doctor": "node bin/specwise.mjs doctor",
    "cli:inventory": "node bin/specwise.mjs inventory examples/legacy-staff-evaluation/input --out ./tmp/inventory-legacy --force",
    "cli:draft": "node bin/specwise.mjs draft examples/legacy-staff-evaluation/input --out ./tmp/draft-legacy --force",
    "cli:provider": "node bin/specwise.mjs provider list",
    "cli:provider:doctor": "node bin/specwise.mjs provider doctor --config examples/config/specwise.mock.config.json",
    "cli:provider:placeholder": "node bin/specwise.mjs provider doctor --config examples/config/specwise.openai-compatible.placeholder.json",
    "cli:extract:dry-run": "node bin/specwise.mjs extract examples/legacy-staff-evaluation/input --out ./tmp/extract-dry-run --config examples/config/specwise.mock.config.json --dry-run",
    "cli:patch:validate": "node bin/specwise.mjs patch validate examples/ai-patches/legacy-staff-evaluation.mock-ai-patch.json",
    "cli:ai-preview:prepare": "node bin/specwise.mjs ai-preview prepare examples/legacy-staff-evaluation/input --out ./tmp/ai-preview-prepare --config examples/config/specwise.ai-preview.example.json --force",
    "cli:review:validate": "node bin/specwise.mjs review validate examples/reviews/legacy-staff-evaluation.review-decisions.example.json",
    "cli:apply-plan:validate": "node bin/specwise.mjs apply-plan validate examples/apply-plans/legacy-staff-evaluation.manual-apply-plan.example.json",
    "cli:handoff:manifest:example": "node --input-type=module -e \"import fs from 'node:fs'; import { validateHandoffManifestDocument } from './src/handoff/validate-handoff-pack.mjs'; validateHandoffManifestDocument(JSON.parse(fs.readFileSync('examples/handoff/legacy-staff-evaluation.handoff-manifest.example.json', 'utf8'))); console.log('SpecWise handoff manifest example validation passed');\"",
    "cli:dx": "node scripts/check-cli-dx.mjs",
    "draft:quality": "node scripts/check-draft-quality.mjs",
    "field:quality": "node scripts/check-field-inference.mjs",
    "smoke": "node scripts/smoke-test-local.mjs",
    "test": "npm run validate:examples && npm run validate:invalid && npm run draft:quality && npm run field:quality && npm run cli:dx"
  },
  "engines": {
    "node": ">=18"
  }
}
